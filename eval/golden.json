{
  "test_cases": [
    {
      "question": "Show me all active bonds maturing in 2025",
      "expected_product": "instrument_master",
      "expected_query_type": "sql",
      "must_contain_columns": ["instrument_id", "instrument_name", "maturity_date"],
      "must_contain_predicates": ["status_code = 'A'", "maturity_date"]
    },
    {
      "question": "What are the high yield bonds?",
      "expected_product": "instrument_master",
      "expected_query_type": "sql",
      "must_contain_columns": ["instrument_id", "rating_sp"],
      "must_contain_predicates": ["rating_sp"]
    },
    {
      "question": "List all equities traded on NYSE",
      "expected_product": "instrument_master",
      "expected_query_type": "sql",
      "must_contain_columns": ["instrument_id"],
      "must_contain_predicates": ["exchange_code"]
    },
    {
      "question": "Find the ISIN for Treasury bonds",
      "expected_product": "instrument_master",
      "expected_query_type": "sql",
      "must_contain_columns": ["isin_code"],
      "must_contain_predicates": []
    },
    {
      "question": "How many active instruments do we have by asset class?",
      "expected_product": "instrument_master",
      "expected_query_type": "sql",
